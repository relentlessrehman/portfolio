# Copy to .env and fill in — see docs/BACKEND.md for the full setup guide.
# Every value here is optional: without them, the contact form and analytics
# degrade gracefully (visitors still see the mailto/copy-email fallback) and
# the /dashboard route reports itself unavailable.

# Supabase — create a free project at supabase.com, then
# Project Settings -> API for these two values. VITE_-prefixed because the
# anon key is safe to expose publicly (RLS governs what it can do) and it's
# used by the contact form / analytics inserts.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service-role key (same page, "service_role" secret). Server-only — powers
# the private dashboard. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# The password you type into the /dashboard sign-in form. Pick anything.
DASHBOARD_PASSWORD=

# Private key used to seal the dashboard's session cookie. Must be at least
# 32 characters, unrelated to DASHBOARD_PASSWORD. Generate with:
#   openssl rand -hex 32
DASHBOARD_SESSION_SECRET=

# Two extra security questions required alongside the password to sign in.
# Question text is shown on the sign-in form; answers are never sent to the
# client. Answers are matched case-insensitively.
DASHBOARD_SECURITY_QUESTION_1=
DASHBOARD_SECURITY_ANSWER_1=
DASHBOARD_SECURITY_QUESTION_2=
DASHBOARD_SECURITY_ANSWER_2=

# Optional: email notification when a contact message arrives (resend.com).
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=
