# Copy to .env and fill in — see docs/BACKEND.md for the full setup guide.
# Every value here is optional: without them, the contact form and analytics
# degrade gracefully (visitors still see the mailto/copy-email fallback) and
# the /dashboard route reports itself unavailable.

# Supabase — create a free project at supabase.com, then
# Project Settings -> API for these two values. VITE_-prefixed because the
# anon key is safe to expose publicly (RLS governs what it can do) and the
# dashboard's magic-link sign-in needs it in the browser too.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service-role key (same page, "service_role" secret). Server-only — powers
# the private dashboard. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# The only email allowed to sign in to /dashboard.
DASHBOARD_ALLOWED_EMAIL=

# Optional: email notification when a contact message arrives (resend.com).
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=
